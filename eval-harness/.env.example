# Copy this file to .env and fill in your key.
# The harness reads ANTHROPIC_API_KEY automatically via your shell environment.
# If you prefer dotenv, run: node --env-file=.env npx tsx src/index.ts ...
# OR simply export the variable in your shell before running npm commands:
#   macOS/Linux:  export ANTHROPIC_API_KEY=sk-ant-...
#   Windows PS:   $env:ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_API_KEY=sk-ant-your-key-here
